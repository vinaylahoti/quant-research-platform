# WS9 paper trading — alert credentials
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
#
# Gmail setup (required for dead-man's switch alerts):
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to myaccount.google.com → Security → App passwords.
#   3. Create an App Password for "Mail" on "Other device".
#   4. Paste the 16-character password below (no spaces).
#
# The sender and recipient can be the same address.

GMAIL_SENDER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_TO_EMAIL=vinaylahoti0@gmail.com
