# WS9 paper trading — alert credentials
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
#
# Resend (replaces Gmail SMTP — Railway blocks outbound SMTP on all ports):
#   1. Sign up at https://resend.com (free tier: 3,000 emails/month)
#   2. Create an API key at resend.com/api-keys
#   3. Paste it below.
#
# ALERT_FROM_EMAIL is optional. If unset, alerts come from onboarding@resend.dev
# (Resend's shared sender, works immediately on free tier without domain setup).
# To use your own domain as the from address, verify it in the Resend dashboard.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_TO_EMAIL=vinaylahoti0@gmail.com
# ALERT_FROM_EMAIL=alerts@yourdomain.com
